{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A potential client lead captured via forms.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the lead" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "phone": { "type": "string", "description": "Phone number" },
        "message": { "type": "string", "description": "Message or project details" },
        "service": { "type": "string", "description": "Service interested in" },
        "source": { "type": "string", "description": "Where the lead came from (e.g., contact, popup)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of submission" }
      },
      "required": ["name", "email", "message"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of captured leads."
    }
  }
}
